*.mod*
*.cmd
.tmp_versions/
modules.order
Module.symvers
Mkfile.old
dkms.conf

build/
managed_components/

# Generated per-build config. MUST NOT be committed: a stale committed
# sdkconfig silently overrides sdkconfig.defaults.* and was the root cause
# of the Thread config drift (FTD/OT-disabled builds despite correct defaults).
sdkconfig
sdkconfig.old
.esphome/
venv/
.cache/

# clean_build_and_flash.sh tees build/flash/monitor output to these. Debug
# artifacts, not source - never commit them (they were previously tracked
# and pushed via push_logs.sh, which is why this rule exists now).
build_log.txt
monitor_log.txt
extra_monitor_log.txt
overnight_log.txt
